# ─────────────────────────────────────────────────────────────
# Mahakama Access — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Both Render and Vercel use these same variables.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── MongoDB Atlas ───────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB=mahakama_access

# ── Authentication ──────────────────────────────────────────
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# ── Client URL (your deployment URL) ────────────────────────
# Render:   https://mahakama-access.onrender.com
# Vercel:   https://your-project.vercel.app
CLIENT_URL=https://mahakama-access.onrender.com

# ── Default Admin Account ───────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Rosh@31059
DEFAULT_ADMIN_ID=001
DEFAULT_ADMIN_NAME=Alex Johnson

# ── Gmail SMTP (for notifications) ──────────────────────────
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@mahakamaaccess.com
